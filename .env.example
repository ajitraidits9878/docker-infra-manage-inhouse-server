# =========================================
# Docker Infrastructure Settings
# Copy this file to .env and change values
# =========================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=super_secret_root_password
MYSQL_DATABASE=default_db
MYSQL_USER=app_user
MYSQL_PASSWORD=super_secret_app_password

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=super_secret_postgres_password
POSTGRES_DB=default_db

# --- phpMyAdmin ---
PHPMYADMIN_PORT=8082

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=super_secret_pgadmin_password
PGADMIN_PORT=8083

# --- FreeRADIUS ---
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# --- MinIO ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=super_secret_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Nginx Proxy Manager ---
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81

# --- Dozzle ---
DOZZLE_PORT=8080
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=super_secret_dozzle_password

# --- Redis ---
REDIS_PASSWORD=super_secret_redis_password
REDIS_PORT=6379

# --- Portainer ---
PORTAINER_PORT=9443

# =========================================
# Phase 2 Services
# =========================================

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=super_secret_mongo_password
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=super_secret_mongo_express
MONGO_EXPRESS_PORT=8081

# --- ELK Stack ---
ELASTIC_PASSWORD=super_secret_elastic_password
KIBANA_PORT=5601

# --- Netdata ---
NETDATA_PORT=19999

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=super_secret_rabbitmq_password
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# --- Uptime Kuma ---
UPTIME_KUMA_PORT=3001
